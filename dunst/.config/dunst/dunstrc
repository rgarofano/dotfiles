[global]
    monitor = 0
    follow = mouse

    width = (500,500)
    height = (0, 150)
    origin = top-right
    offset = (16, 36)

    scale = 0

    notification_limit = 5

    font = FiraCode Nerd Font 12

    frame_width = 3
    separator_height = 1

    padding = 16
    horizontal_padding = 16

    transparency = 0

    corner_radius = 0

    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center

    show_age_threshold = 60
    word_wrap = true

    stack_duplicates = true
    hide_duplicate_count = false

    gap_size = 8

    show_indicators = false

    dmenu = dmenu -p dunst:

    icon_position = left
    min_icon_size = 48
    max_icon_size = 48

    sticky_history = true
    history_length = 20

    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    background = "#222222"
    foreground = "#bbbbbb"
    timeout = 5

[urgency_normal]
    background = "#222222"
    foreground = "#ffffff"
    timeout = 5

[urgency_critical]
    background = "#222222"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    timeout = 0
